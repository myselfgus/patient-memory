# Copie para .env (ou exporte no shell). NUNCA versione segredos reais.

# Caminho do banco SQLite da memória (um por instalação; pacientes são namespaced internamente)
MEMORY_DB=./memory.db

# Embedder dos trechos de evidência:
#   offline -> determinístico, lexical, sem chave (default; bom p/ dev/testes)
#   openai  -> text-embedding-3-small via API (semântico de verdade)
MEMORY_EMBEDDER=offline

# Só necessárias se MEMORY_EMBEDDER=openai ou se for usar project.py:
# OPENAI_API_KEY=
# MEMORY_EMBEDDER_MODEL=text-embedding-3-small
# MEMORY_PROJECTION_MODEL=gpt-4o-mini
